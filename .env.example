APP_NAME=Historical Guide RAG Agent
DEBUG=false

# SQLAlchemy connection string (used by backend/app/config.py)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/historical_guide

# PostgreSQL settings (used by Docker Compose and local tooling)
POSTGRES_DB=historical_guide
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Embeddings (used by backend/app/config.py)
EMBEDDING_PROVIDER=e5
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# LLM — Groq (https://console.groq.com/keys)
# Set LLM_API_KEY in your local .env before using POST /api/chat with a real model.
# Use LLM_PROVIDER=mock for offline development without an API key.
LLM_PROVIDER=groq
LLM_MODEL_NAME=llama-3.1-8b-instant
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=300
LLM_TIMEOUT_SECONDS=30

# RAG agent retrieval
RAG_TOP_K=3
RAG_TOP_K_COMPLEX=5
RAG_MIN_SCORE=0.65
RAG_SCORE_GAP_FROM_BEST=0.08

# Optional web search fallback
# WEB_SEARCH_PROVIDER: duckduckgo (free, no key) or tavily (API key required)
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_REGION=fr-fr
WEB_SEARCH_TIMEOUT_SECONDS=15
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic

# Logging (backend/app/logging_config.py)
LOG_LEVEL=INFO
