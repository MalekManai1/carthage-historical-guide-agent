# Leave empty in dev — Vite proxies /api to localhost:8000
VITE_API_URL=

# Alternative name (used if VITE_API_URL is empty)
# VITE_API_BASE_URL=http://localhost:8000

# Show session memory in chat (debug only)
# VITE_DEBUG_MEMORY=true

# For production build pointing at a remote API:
# VITE_API_URL=https://your-api.example.com

# OSRM route geometry on the circuit map (free public demo server)
VITE_OSRM_ENABLED=true
VITE_OSRM_BASE_URL=https://router.project-osrm.org
VITE_OSRM_PROFILE=driving
